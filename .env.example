# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored and is never committed or published.

# Contact email sent with NCBI E-utilities requests (NCBI politeness convention).
NCBI_EMAIL=you@example.com

# Optional. A free NCBI API key raises the rate limit from 3/s to 10/s.
# Get one at https://www.ncbi.nlm.nih.gov/account/ ; leave blank to omit.
NCBI_API_KEY=

# Optional. Max literature searches served concurrently (default 2).
MAX_CONCURRENT_SEARCHES=2

# Optional. Override the on-disk cache location (defaults to a system temp dir).
# CACHE_PATH=/tmp/glm_cache.sqlite
